            "code": "// Function to enable scrolling\nfunction enableScrolling() {\n    // Allow vertical scrolling\n    document.body.style.overflowY = 'scroll';\n\n    // Remove event listener for upward scrolling\n    window.addEventListener('scroll', function(e) {\n        if (window.scrollY < previousScrollY) {\n            e.preventDefault();\n        }\n    });\n\n    let previousScrollY = window.scrollY;\n\n    // Monitor scroll events and save previous position\n    window.addEventListener('scroll', function() {\n        previousScrollY = window.scrollY;\n    });\n}\n\n// Function to start the scroll script\nfunction startScrollScript() {\n    enableScrolling();\n    setTimeout(() => {\n        // Repeat every 2 seconds\n        setInterval(enableScrolling, 2000);\n    }, 700);\n}\n\n// Start the script\nstartScrollScript();",
